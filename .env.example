# My Care Academy — environment variables
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored. NEVER commit secret values.

# --- Supabase (required now) ---
# Project URL is not secret. Region: Central EU / Frankfurt (eu-central-1); UK data under UK-EU adequacy.
NEXT_PUBLIC_SUPABASE_URL=https://khocrtocozzpayvelvhk.supabase.co
# Public anon key (safe to expose to the browser; RLS enforces access).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only admin key that BYPASSES RLS. Keep secret. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Phase 9) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price ids per tier (created by scripts/setup-stripe.mjs)
STRIPE_PRICE_CORE=
STRIPE_PRICE_CORE_FORMS=
STRIPE_PRICE_CORE_RECRUITMENT=
STRIPE_PRICE_FULL=

# --- Cron ---
# Shared secret guarding /api/cron/* routes. Set the same value in Vercel; Vercel
# Cron automatically sends it as a Bearer token.
CRON_SECRET=

# --- Auth ---
# Set to "false" to disable forcing admins through MFA (AAL2). Defaults to enforced.
MFA_ENFORCED=true

# --- Email / Resend (Phase 1b onward) ---
RESEND_API_KEY=

# Unsplash API (stock photos for training content authoring)
UNSPLASH_ACCESS_KEY=
